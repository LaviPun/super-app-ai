# Platform V2 job ledger — local / staging / production
# Copy to .env.local (never commit secrets).

# In-memory (default for unit tests)
# JOB_STORE_PROVIDER=memory

# SQLite (local dev without Postgres)
JOB_STORE_PROVIDER=repository
JOB_LEDGER_DRIVER=sqlite
JOB_LEDGER_SQLITE_PATH=./tmp/v2-job-ledger.sqlite

# Postgres (staging/prod — apply migration first)
# JOB_STORE_PROVIDER=repository
# JOB_LEDGER_DRIVER=postgres
# V2_DATABASE_URL=postgresql://user:pass@host:5432/superapp_v2?sslmode=require
#
# psql "$V2_DATABASE_URL" -f packages/db/migrations/0001_v2_job_ledger.sql
