# Internal AI router — Railway service env (no secrets in git).
# Copy values into the Railway dashboard or link via Railway shared variables.

ROUTER_HOST=0.0.0.0
# Optional on Railway — the service listens on injected PORT when ROUTER_PORT is unset.
# ROUTER_PORT=8787
ROUTER_BACKEND=ollama
ROUTER_OLLAMA_BASE_URL=https://your-ollama-or-vllm-host:11434
ROUTER_OLLAMA_MODEL=qwen3:4b-instruct
ROUTER_OPENAI_BASE_URL=
ROUTER_OPENAI_MODEL=
ROUTER_OPENAI_API_KEY=
ROUTER_MODEL_TIMEOUT_MS=2500
ROUTER_BODY_MAX_BYTES=8192
ROUTER_RATE_WINDOW_MS=60000
ROUTER_RATE_MAX_REQUESTS=90
ROUTER_TENANT_MAX_ACTIVE_REQUESTS=1
ROUTER_TENANT_RATE_MAX_REQUESTS=30
ROUTER_TENANT_RATE_WINDOW_MS=60000

# Secret — set in Railway, never commit:
# INTERNAL_AI_ROUTER_TOKEN=
