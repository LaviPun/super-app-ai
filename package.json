{
  "name": "ai-shopify-superapp",
  "private": true,
  "packageManager": "pnpm@9.12.2",
  "scripts": {
    "dev": "pnpm -r dev",
    "dev:web": "pnpm --filter web dev",
    "shopify:dev": "shopify app dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "evals": "pnpm --filter web evals",
    "evals:strict": "pnpm --filter web evals --strict",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1"
  },
  "lint-staged": {
    "apps/web/app/**/*.{ts,tsx}": [
      "pnpm --filter web eslint --fix"
    ],
    "**/*.{ts,tsx,js}": [
      "bash -c 'pnpm -r --if-present typecheck || true'"
    ]
  }
}
