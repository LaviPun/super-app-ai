{
  "name": "ai-shopify-superapp",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.20.0",
    "pnpm": ">=9.15.0"
  },
  "scripts": {
    "dev": "pnpm -r dev",
    "dev:web": "pnpm --filter web dev",
    "shopify:dev": "shopify app dev",
    "build": "pnpm -r build",
    "test": "pnpm --filter @superapp/platform-contracts build && pnpm --filter @superapp/security build && pnpm --filter @superapp/job-orchestration build && pnpm --filter @superapp/workers build && pnpm --filter web exec prisma generate && pnpm -r test",
    "lint": "pnpm -r lint",
    "evals": "pnpm --filter web evals",
    "evals:strict": "pnpm --filter web evals --strict",
    "prepare": "husky",
    "test:v2": "node scripts/v2-test-matrix.mjs --continue",
    "test:v2:fast": "node scripts/v2-test-matrix.mjs --skip=evals,evals-strict,e2e",
    "test:v2:ci": "node scripts/v2-test-matrix.mjs",
    "test:v2:typecheck": "pnpm --filter @superapp/platform-contracts --filter @superapp/db --filter @superapp/network-security --filter @superapp/core --filter @superapp/rate-limit --filter @superapp/api --filter @superapp/workers --filter @superapp/frontend typecheck",
    "test:v2:unit": "pnpm --filter @superapp/platform-contracts --filter @superapp/db --filter @superapp/network-security --filter @superapp/core --filter @superapp/rate-limit --filter @superapp/api --filter @superapp/workers --filter @superapp/frontend test",
    "test:v2:build": "pnpm --filter @superapp/platform-contracts --filter @superapp/db --filter @superapp/network-security --filter @superapp/core --filter @superapp/api --filter @superapp/workers --filter @superapp/frontend build",
    "deploy:validate": "pnpm --filter web exec tsx ../../scripts/deployment/validate-config.ts",
    "test:deployment": "pnpm --filter web exec vitest run --config ../../scripts/deployment/vitest.config.ts"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "vitest": ">=3.2.6 <4"
  },
  "pnpm": {
    "overrides": {
      "protobufjs": ">=8.0.1",
      "shell-quote": ">=1.8.4",
      "vitest": ">=3.2.6 <4",
      "ioredis": "^5.11.1"
    }
  },
  "lint-staged": {
    "apps/web/app/**/*.{ts,tsx}": [
      "pnpm --filter web eslint --fix"
    ],
    "**/*.{ts,tsx,js}": [
      "bash -c 'pnpm -r --if-present typecheck || true'"
    ]
  }
}
