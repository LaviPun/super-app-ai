{%# theme-check-disable OrphanedSnippet,RemoteAsset%}
{%liquid
assign layout_class=''
assign layout_cols=''
assign layout_kind=mod_cfg.layout.layout|handle
if layout_kind != blank and layout_kind != 'stacked'
assign layout_class=' superapp-layout--'|append:layout_kind
endif
if mod_cfg.layout.columns != blank
assign sa_cols_req=mod_cfg.layout.columns|at_least:1|at_most:4
if mod_cfg.blocks != blank and mod_cfg.blocks.size > 0 and mod_cfg.blocks.size < sa_cols_req
assign sa_cols_req=mod_cfg.blocks.size
endif
assign layout_cols=' style="--sa-cols:'|append:sa_cols_req|append:'"'
endif
assign sa_sec_has_blocks=false
if mod_cfg.blocks != blank and mod_cfg.blocks.size > 0
assign sa_sec_has_blocks=true
endif
assign sa_sec_block_has_image=false
if sa_sec_has_blocks
for sa_blk in mod_cfg.blocks
if sa_blk.imageUrl != blank
assign sa_sec_block_has_image=true
break
endif
endfor
endif
assign sa_sec_variant=''
unless mod_cfg.imageUrl != blank or mod_cfg.body != blank or sa_sec_has_blocks
assign sa_sec_variant=' superapp-section--minimal'
endunless
if sa_sec_has_blocks and sa_sec_block_has_image == false
assign sa_sec_variant=sa_sec_variant|append:' superapp-section--textonly'
endif
assign sa_sec_empty=false
if mod_cfg.title == blank and mod_cfg.subtitle == blank and mod_cfg.body == blank and sa_sec_has_blocks == false and mod_cfg.ctaText == blank
assign sa_sec_empty=true
endif
assign sa_arch='generic'
assign sa_kind_h=kind|handle
case sa_kind_h
when 'hero','collection-hero'
assign sa_arch='hero'
when 'feature','benefit'
if sa_sec_has_blocks
assign sa_arch='feature'
endif
when 'gallery','lookbook','collection-lookbook','collection-carousel','ugc-grid','before-after','hotspots'
if sa_sec_has_blocks
assign sa_arch='gallery'
endif
when 'collection-story','collection-split','collection-promo','collection-list','story'
assign sa_arch='collection'
when 'pricing','comparison','plan','volume-tiers'
if sa_sec_has_blocks
assign sa_arch='pricing'
endif
when 'faq','accordion','tabs'
if sa_sec_has_blocks
assign sa_arch='faq'
endif
when 'testimonial','testimonials','reviews','social-proof','review-summary'
if sa_sec_has_blocks
assign sa_arch='testimonial'
endif
when 'stats'
if sa_sec_has_blocks
assign sa_arch='stats'
endif
when 'cta','rich-text'
assign sa_arch='cta'
when 'trust','trust-badges','trust-badge','payment-badges','usp-strip','logo-marquee'
if sa_sec_has_blocks
assign sa_arch='trust'
endif
when 'newsletter'
assign sa_arch='newsletter'
when 'launch','coming-soon','404'
assign sa_arch='launch'
when 'contact'
assign sa_arch='contact'
when 'team'
if sa_sec_has_blocks
assign sa_arch='team'
endif
when 'timeline','steps'
if sa_sec_has_blocks
assign sa_arch='timeline'
endif
when 'upsell','bought-together','product-addons'
if sa_sec_has_blocks
assign sa_arch='upsell'
endif
when 'post-atc-offer'
assign sa_arch='upsell'
when 'announcement','announcement-bar','free-shipping-bar','countdown','countdown-bar','progress','progress-bar','stock-counter'
assign sa_arch='band'
when 'pdp','product-page','product-detail','buy-box'
assign sa_arch='pdp'
when 'sticky-atc','sticky-add-to-cart','atc-bar'
assign sa_arch='sticky-atc'
when 'consent','json-ld','meta','pixel-bootstrap','preload','filters','search','sort','size-chart','star-rating','payment-icons','footer','rewards','badge'
assign sa_arch='technical'
endcase
assign sa_self_header=false
if sa_arch == 'launch' or sa_arch == 'hero' or sa_arch == 'cta' or sa_arch == 'collection' or sa_arch == 'contact' or sa_arch == 'band' or sa_arch == 'newsletter' or sa_arch == 'technical' or sa_arch == 'pdp' or sa_arch == 'sticky-atc'
assign sa_self_header=true
endif
%}
<section class="superapp-section superapp-section--{{kind|handle}}{{layout_class}}{{sa_sec_variant}} sa-reveal"{{layout_cols}} data-module-id="{{module_id|escape}}" data-section-kind="{{kind|escape}}"><div class="superapp-section__inner superapp-container">{%if sa_sec_empty%}<div class="superapp-section__empty" role="note">Nothing to show yet</div>{%endif%}{%unless sa_self_header%}{%if mod_cfg.title != blank%}<h2 class="superapp-section__title">{{mod_cfg.title|escape}}</h2>{%endif%}{%if mod_cfg.subtitle != blank%}<p class="superapp-section__sub superapp-measure">{{mod_cfg.subtitle|escape}}</p>{%endif%}{%endunless%}{%case sa_arch%}{%when 'hero'%}{%assign hero_variant='centered'%}{%assign hero_media=mod_cfg.fields.mediaImageUrl|default:mod_cfg.fields.backgroundImageUrl|default:mod_cfg.fields.posterImageUrl%}{%if mod_cfg.fields.mediaImageUrl != blank or mod_cfg.layout.layout == 'grid'%}{%assign hero_variant='split'%}{%endif%}{%if mod_cfg.fields.backgroundImageUrl != blank or mod_cfg.fields.videoUrl != blank or mod_cfg.fields.overlayStrength != blank%}{%assign hero_variant='overlay'%}{%endif%}<div class="superapp-hero superapp-hero--{{hero_variant}}">{%assign hero_video=mod_cfg.fields.videoUrl%}{%if hero_video != blank%}{%assign hero_poster=hero_media|default:mod_cfg.imageUrl%}{%assign hero_ov=mod_cfg.fields.overlayOpacity|default:0.4%}{%assign yt_id=''%}{%if hero_video contains 'youtu'%}{%if hero_video contains 'watch?v='%}{%assign yt_id=hero_video|split:'watch?v='|last|split:'&'|first%}{%elsif hero_video contains 'youtu.be/'%}{%assign yt_id=hero_video|split:'youtu.be/'|last|split:'?'|first%}{%elsif hero_video contains '/embed/'%}{%assign yt_id=hero_video|split:'/embed/'|last|split:'?'|first%}{%endif%}{%endif%}{%assign vim_id=''%}{%if yt_id == blank and hero_video contains 'vimeo.com/'%}{%assign vim_id=hero_video|split:'/'|last|split:'?'|first%}{%endif%}{%assign v_src=''%}{%if yt_id != blank%}{%assign v_src='https://www.youtube-nocookie.com/embed/'|append:yt_id|append:'?rel=0&playsinline=1&modestbranding=1'%}{%if mod_cfg.fields.autoplay%}{%assign v_src=v_src|append:'&autoplay=1&mute=1'%}{%if mod_cfg.fields.loop%}{%assign v_src=v_src|append:'&loop=1&playlist='|append:yt_id%}{%endif%}{%endif%}{%elsif vim_id != blank%}{%assign v_src='https://player.vimeo.com/video/'|append:vim_id|append:'?dnt=1&playsinline=1'%}{%if mod_cfg.fields.autoplay%}{%assign v_src=v_src|append:'&autoplay=1&muted=1'%}{%if mod_cfg.fields.loop%}{%assign v_src=v_src|append:'&loop=1'%}{%endif%}{%endif%}{%endif%}{%if v_src != blank%}<iframe class="superapp-hero__video" src="{{v_src}}" title="{{mod_cfg.title|escape}}" loading="lazy" allow="autoplay; fullscreen; encrypted-media; picture-in-picture" allowfullscreen></iframe>{%else%}<video class="superapp-hero__video" data-sa-hero-video{%if hero_poster != blank%} poster="{{hero_poster|escape}}"{%endif%}{%unless mod_cfg.fields.muted == false%} muted{%endunless%}{%if mod_cfg.fields.loop%} loop{%endif%} playsinline preload="metadata"{%if mod_cfg.fields.autoplay%} autoplay{%endif%}><source src="{{hero_video|escape}}" type="video/mp4"></video>{%endif%}<span class="superapp-hero__scrim" aria-hidden="true" style="opacity:{{hero_ov}}"></span>{%elsif hero_media != blank%}<img class="superapp-hero__media" src="{{hero_media|escape}}" alt="{{mod_cfg.fields.mediaAlt|default:mod_cfg.fields.backgroundAlt|escape}}" loading="lazy" width="1200" height="900">{%endif%}<div class="superapp-hero__content">{%if mod_cfg.fields.eyebrow != blank%}<span class="superapp-hero__eyebrow">{{mod_cfg.fields.eyebrow|escape}}</span>{%endif%}{%if mod_cfg.title != blank%}<h2 class="superapp-hero__title">{{mod_cfg.title|escape}}</h2>{%endif%}{%if mod_cfg.subtitle != blank%}<p class="superapp-hero__subtitle superapp-measure">{{mod_cfg.subtitle|escape}}</p>{%endif%}{%assign hero_body=mod_cfg.fields.bodyText|default:mod_cfg.body%}{%if hero_body != blank%}<p class="superapp-hero__body superapp-measure">{{hero_body|escape|newline_to_br}}</p>{%endif%}{%if mod_cfg.blocks != blank%}{%assign hero_ctas=mod_cfg.blocks|where:'kind','cta'%}{%if hero_ctas.size > 0%}<div class="superapp-hero__ctas superapp-cluster">{%for section_block in hero_ctas%}{%assign hero_cta_style=section_block.fields.style|default:'primary'|handle%}{%if section_block.url != blank%}<a class="superapp-hero__cta superapp-hero__cta--{{hero_cta_style}}" href="{{section_block.url|escape}}">{{section_block.text|default:'Shop now'|escape}}</a>{%endif%}{%endfor%}</div>{%endif%}{%assign hero_stats=mod_cfg.blocks|where:'kind','stat'%}{%assign hero_feats=mod_cfg.blocks|where:'kind','feature'%}{%if hero_stats.size > 0 or hero_feats.size > 0%}<div class="superapp-hero__proof">{%for section_block in hero_stats%}<div class="superapp-hero__proofitem"><span class="superapp-hero__proofvalue">{{section_block.fields.value|default:section_block.text|escape}}</span>{%if section_block.fields.label != blank%}<span class="superapp-hero__prooflabel">{{section_block.fields.label|escape}}</span>{%endif%}</div>{%endfor%}{%for section_block in hero_feats%}<div class="superapp-hero__proofitem"><span class="superapp-hero__proofvalue">{{section_block.fields.heading|default:section_block.text|escape}}</span></div>{%endfor%}</div>{%endif%}{%endif%}</div></div>{%when 'feature'%}{%assign feat_variant='grid'%}{%if mod_cfg.layout.layout == 'bento' or mod_cfg.layout.layout == 'masonry'%}{%assign feat_variant='bento'%}{%endif%}<div class="superapp-feature superapp-feature--{{feat_variant}}">{%for section_block in mod_cfg.blocks%}{%assign feat_title=section_block.fields.heading|default:section_block.text%}{%if feat_title != blank%}<div class="superapp-feature__item{%if section_block.fields.span == 'wide' or section_block.fields.span == 'feature'%} superapp-feature__item--wide{%endif%}">{%if section_block.fields.icon != blank%}<span class="superapp-feature__icon" data-icon="{{section_block.fields.icon|escape}}" aria-hidden="true"></span>{%endif%}<h3 class="superapp-feature__title">{{feat_title|escape}}</h3>{%if section_block.fields.heading != blank and section_block.text != blank%}<p class="superapp-feature__text">{{section_block.text|escape|newline_to_br}}</p>{%endif%}</div>{%endif%}{%endfor%}</div>{%when 'gallery'%}{%if sa_kind_h == 'before-after'%}<div class="superapp-beforeafter" data-start="{{mod_cfg.startPercent|default:50}}">{%assign ba_i=0%}{%for section_block in mod_cfg.blocks%}{%if section_block.imageUrl != blank and ba_i < 2%}<figure class="superapp-beforeafter__pane"><img src="{{section_block.imageUrl|escape}}" alt="{{section_block.fields.alt|default:section_block.text|escape}}" loading="lazy" width="1000" height="1000">{%if section_block.text != blank%}<figcaption>{{section_block.text|escape}}</figcaption>{%endif%}</figure>{%assign ba_i=ba_i|plus:1%}{%endif%}{%endfor%}</div>{%elsif sa_kind_h == 'hotspots'%}{%assign hs_base=mod_cfg.imageUrl|default:mod_cfg.fields.imageUrl%}<div class="superapp-hotspots">{%if hs_base != blank%}<img class="superapp-hotspots__base" src="{{hs_base|escape}}" alt="{{mod_cfg.fields.imageAlt|default:mod_cfg.title|escape}}" loading="lazy" width="1200" height="900">{%endif%}<script type="application/json" data-sa-hotspots-config>{{mod_cfg.blocks|json}}</script><ul class="superapp-hotspots__list">{%for section_block in mod_cfg.blocks%}{%if section_block.kind == 'hotspot'%}<li>{%if section_block.url != blank%}<a href="{{section_block.url|escape}}">{%endif%}{{section_block.text|default:section_block.fields.title|default:'Shop this'|escape}}{%if section_block.fields.price != blank%}<span class="superapp-hotspots__price">{{section_block.fields.price|escape}}</span>{%endif%}{%if section_block.url != blank%}</a>{%endif%}</li>{%endif%}{%endfor%}</ul></div>{%else%}{%assign gal_variant=mod_cfg.layout.layout|default:'grid'|handle%}{%if gal_variant == blank or gal_variant == 'stacked'%}{%assign gal_variant='grid'%}{%endif%}{%assign gal_ugc=false%}{%if sa_kind_h == 'ugc-grid'%}{%assign gal_ugc=true%}{%endif%}<div class="superapp-gallery superapp-gallery--{{gal_variant}}{%if gal_ugc%} superapp-gallery--ugc{%endif%}">{%for section_block in mod_cfg.blocks%}{%if section_block.imageUrl != blank%}{%assign gal_cap=section_block.fields.caption|default:section_block.text%}<figure class="superapp-gallery__item{%if gal_ugc%} superapp-gallery__item--ugc{%endif%}{%if section_block.fields.span != blank%} superapp-gallery__item--{{section_block.fields.span|handle}}{%endif%}">{%if section_block.url != blank and gal_ugc == false%}<a class="superapp-gallery__link" href="{{section_block.url|escape}}">{%endif%}<img src="{{section_block.imageUrl|escape}}" alt="{{section_block.fields.alt|default:section_block.text|escape}}" loading="lazy" width="600" height="600">{%if section_block.url != blank and gal_ugc == false%}</a>{%endif%}{%if gal_ugc%}{%assign gal_shop=section_block.fields.productUrl|default:section_block.url%}<figcaption class="superapp-gallery__ugc" tabindex="0">{%if gal_cap != blank%}<span class="superapp-gallery__ugccap">{{gal_cap|escape}}</span>{%endif%}{%if section_block.fields.authorHandle != blank%}<span class="superapp-gallery__ugchandle">@{{section_block.fields.authorHandle|remove:'@'|escape}}</span>{%endif%}{%if gal_shop != blank%}<a class="superapp-gallery__ugcshop" href="{{gal_shop|escape}}">{{section_block.fields.shopLabel|default:'Shop this'|escape}}</a>{%endif%}</figcaption>{%elsif gal_cap != blank%}<figcaption class="superapp-gallery__caption">{{gal_cap|escape}}</figcaption>{%endif%}</figure>{%endif%}{%endfor%}</div>{%endif%}{%when 'collection'%}{%assign coll_media=mod_cfg.fields.heroImageUrl|default:mod_cfg.fields.mediaImageUrl|default:mod_cfg.imageUrl%}<div class="superapp-collection">{%if coll_media != blank%}<div class="superapp-collection__media"><img src="{{coll_media|escape}}" alt="{{mod_cfg.fields.mediaAlt|escape}}" loading="lazy" width="1200" height="800"></div>{%endif%}<div class="superapp-collection__content">{%if mod_cfg.fields.eyebrow != blank%}<span class="superapp-collection__eyebrow">{{mod_cfg.fields.eyebrow|escape}}</span>{%endif%}{%assign coll_head=mod_cfg.fields.heading|default:mod_cfg.title%}{%if coll_head != blank%}<h2 class="superapp-collection__title">{{coll_head|escape}}</h2>{%endif%}{%assign coll_text=mod_cfg.fields.intro|default:mod_cfg.fields.standfirst|default:mod_cfg.subtitle%}{%if coll_text != blank%}<p class="superapp-collection__text superapp-measure">{{coll_text|escape|newline_to_br}}</p>{%endif%}{%if mod_cfg.blocks != blank%}{%for section_block in mod_cfg.blocks%}{%if section_block.kind == 'story' or section_block.kind == 'tile' or section_block.kind == 'slide'%}<div class="superapp-collection__story">{%if section_block.imageUrl != blank%}<img class="superapp-collection__storyimg" src="{{section_block.imageUrl|escape}}" alt="{{section_block.fields.caption|default:section_block.text|escape}}" loading="lazy" width="800" height="600">{%endif%}{%if section_block.text != blank%}<p class="superapp-collection__text superapp-measure">{{section_block.text|escape|newline_to_br}}</p>{%endif%}{%if section_block.fields.caption != blank%}<span class="superapp-collection__caption">{{section_block.fields.caption|escape}}</span>{%endif%}</div>{%endif%}{%endfor%}{%endif%}{%assign coll_cta_url=mod_cfg.fields.ctaUrl|default:mod_cfg.ctaUrl%}{%if coll_cta_url != blank%}<a class="superapp-collection__cta" href="{{coll_cta_url|escape}}">{{mod_cfg.fields.ctaLabel|default:mod_cfg.ctaText|default:'Shop the collection'|escape}}</a>{%endif%}</div></div>{%when 'cta'%}<div class="superapp-cta">{%if mod_cfg.title != blank%}<h2 class="superapp-cta__title">{{mod_cfg.title|escape}}</h2>{%endif%}{%assign cta_text=mod_cfg.subtitle|default:mod_cfg.fields.bodyText|default:mod_cfg.body%}{%if cta_text != blank%}<p class="superapp-cta__text superapp-measure">{{cta_text|escape|newline_to_br}}</p>{%endif%}{%assign cta_blocks=''%}{%if mod_cfg.blocks != blank%}{%assign cta_blocks=mod_cfg.blocks|where:'kind','cta'%}{%endif%}{%assign cta_show_actions=false%}{%if cta_blocks != blank and cta_blocks.size > 0%}{%assign cta_show_actions=true%}{%endif%}{%if mod_cfg.ctaText != blank and mod_cfg.ctaUrl != blank%}{%assign cta_show_actions=true%}{%endif%}{%if cta_show_actions%}<div class="superapp-cta__actions superapp-cluster">{%if cta_blocks != blank and cta_blocks.size > 0%}{%for section_block in cta_blocks%}{%assign cta_style=section_block.fields.style|default:'primary'|handle%}{%if section_block.url != blank%}<a class="superapp-cta__button superapp-cta__button--{{cta_style}}" href="{{section_block.url|escape}}">{{section_block.text|default:'Get started'|escape}}</a>{%endif%}{%endfor%}{%elsif mod_cfg.ctaText != blank and mod_cfg.ctaUrl != blank%}<a class="superapp-cta__button superapp-cta__button--primary" href="{{mod_cfg.ctaUrl|escape}}">{{mod_cfg.ctaText|escape}}</a>{%endif%}</div>{%endif%}</div>{%when 'contact'%}<div class="superapp-contactcard">{%for section_block in mod_cfg.blocks%}{%if section_block.kind == 'contact-method'%}{%assign cm_value=section_block.fields.detail|default:section_block.url%}<div class="superapp-contactcard__method">{%if section_block.text != blank%}<span class="superapp-contactcard__label">{{section_block.text|escape}}</span>{%endif%}{%if section_block.url != blank%}<a class="superapp-contactcard__value" href="{{section_block.url|escape}}">{{cm_value|escape}}</a>{%elsif cm_value != blank%}<span class="superapp-contactcard__value">{{cm_value|escape}}</span>{%endif%}</div>{%endif%}{%endfor%}</div>{%when 'team'%}<div class="superapp-team">{%for section_block in mod_cfg.blocks%}{%if section_block.kind == 'team-member'%}<figure class="superapp-team__member">{%if section_block.imageUrl != blank%}<img class="superapp-team__photo" src="{{section_block.imageUrl|escape}}" alt="{{section_block.text|escape}}" loading="lazy" width="320" height="320">{%endif%}{%if section_block.text != blank%}<figcaption class="superapp-team__name">{{section_block.text|escape}}</figcaption>{%endif%}{%if section_block.fields.role != blank%}