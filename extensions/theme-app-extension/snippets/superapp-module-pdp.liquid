{%# theme-check-disable OrphanedSnippet%}{%case variant%}{%when 'pdp'%}{%assign pdp_media = ''%}{%if mod_cfg.blocks != blank%}{%assign pdp_media = mod_cfg.blocks|where:'kind','media'%}{%endif%}{%assign pdp_main = mod_cfg.imageUrl%}{%if pdp_main == blank and pdp_media != blank and pdp_media.size > 0%}{%assign pdp_main = pdp_media[0].imageUrl%}{%endif%}{%assign pdp_price = mod_cfg.fields.price%}{%assign pdp_compare = mod_cfg.fields.compareAtPrice%}{%assign pdp_atc_label = mod_cfg.ctaText|default:mod_cfg.fields.ctaLabel|default:'Add to cart'%}<div class="superapp-pdp"><div class="superapp-pdp__gallery">{%if pdp_main != blank%}<img class="superapp-pdp__media" src="{{pdp_main|escape}}" alt="{{mod_cfg.fields.mediaAlt|default:mod_cfg.title|escape}}" loading="lazy" width="900" height="1100">{%endif%}{%if pdp_media != blank and pdp_media.size > 1%}<div class="superapp-pdp__thumbs">{%for section_block in pdp_media offset:1 limit:4%}{%if section_block.imageUrl != blank%}<img class="superapp-pdp__thumb" src="{{section_block.imageUrl|escape}}" alt="{{section_block.text|escape}}" loading="lazy" width="160" height="160">{%endif%}{%endfor%}</div>{%endif%}</div><div class="superapp-pdp__buybox">{%if mod_cfg.fields.eyebrow != blank%}<span class="superapp-pdp__eyebrow">{{mod_cfg.fields.eyebrow|escape}}</span>{%endif%}{%if mod_cfg.title != blank%}<h2 class="superapp-pdp__title">{{mod_cfg.title|escape}}</h2>{%endif%}{%if mod_cfg.fields.rating != blank%}<div class="superapp-pdp__rating"><span class="superapp-pdp__stars" aria-hidden="true">★★★★★</span><span class="superapp-pdp__ratingtext">{{mod_cfg.fields.rating|escape}}{%if mod_cfg.fields.reviewCount != blank%} · {{mod_cfg.fields.reviewCount|escape}} reviews{%endif%}</span></div>{%endif%}{%if pdp_price != blank%}<div class="superapp-pdp__price"><span class="superapp-pdp__amount">{{pdp_price|escape}}</span>{%if pdp_compare != blank%}<s class="superapp-pdp__compare">{{pdp_compare|escape}}</s>{%endif%}</div>{%endif%}{%assign pdp_body = mod_cfg.fields.bodyText|default:mod_cfg.body%}{%if pdp_body != blank%}<p class="superapp-pdp__body">{{pdp_body|escape|newline_to_br}}</p>{%endif%}{%if mod_cfg.blocks != blank%}{%assign pdp_variants = mod_cfg.blocks|where:'kind','variant'%}{%if pdp_variants.size > 0%}<div class="superapp-pdp__variants" role="group" aria-label="Options">{%for section_block in pdp_variants%}<span class="superapp-pdp__variant{%if section_block.fields.selected%} superapp-pdp__variant--selected{%endif%}">{{section_block.text|escape}}</span>{%endfor%}</div>{%endif%}{%endif%}{%if mod_cfg.ctaUrl != blank%}<a class="superapp-pdp__atc" href="{{mod_cfg.ctaUrl|escape}}">{{pdp_atc_label|escape}}</a>{%else%}<button class="superapp-pdp__atc" type="button">{{pdp_atc_label|escape}}</button>{%endif%}{%if mod_cfg.blocks != blank%}{%assign pdp_trust = mod_cfg.blocks|where:'kind','feature'%}{%if pdp_trust.size > 0%}<ul class="superapp-pdp__trust">{%for section_block in pdp_trust limit:3%}<li class="superapp-pdp__trustitem">{{section_block.fields.heading|default:section_block.text|escape}}</li>{%endfor%}</ul>{%endif%}{%endif%}</div></div>{%when 'sticky-atc'%}{%if product != blank%}{%assign satc_watch = mod_cfg.fields.watchSelector|default:'form[action*="/cart/add"]'%}{%assign satc_var = product.selected_or_first_available_variant%}{%assign satc_label = mod_cfg.ctaText|default:mod_cfg.fields.ctaLabel|default:'Add to cart'%}<div class="superapp-satc" data-sa-satc data-watch="{{satc_watch|escape}}" data-money-format="{{shop.money_format|escape}}" hidden>{%if product.featured_image%}<img class="superapp-satc__thumb" src="{{product.featured_image|image_url:width:96}}" alt="" loading="lazy" width="48" height="48">{%endif%}<div class="superapp-satc__meta"><span class="superapp-satc__name">{{product.title|escape}}</span><span class="superapp-satc__price" data-sa-satc-price>{{satc_var.price|money}}{%if satc_var.compare_at_price > satc_var.price%} <s class="superapp-satc__compare">{{satc_var.compare_at_price|money}}</s>{%endif%}</span></div>{%if product.variants.size > 1%}<select class="superapp-satc__variant" data-sa-satc-variant aria-label="{{product.title|escape}} options">{%for v in product.variants%}<option value="{{v.id}}" data-price="{{v.price}}"{%if v.compare_at_price > v.price%} data-compare="{{v.compare_at_price}}"{%endif%}{%unless v.available%} disabled{%endunless%}{%if v.id == satc_var.id%} selected{%endif%}>{{v.title|escape}}</option>{%endfor%}</select>{%else%}<input type="hidden" data-sa-satc-variant value="{{satc_var.id}}">{%endif%}<input class="superapp-satc__qty" type="number" inputmode="numeric" min="1" value="1" data-sa-satc-qty aria-label="Quantity"><button class="superapp-satc__atc" type="button" data-sa-satc-add{%unless satc_var.available%} disabled{%endunless%}>{{satc_label|escape}}</button><span class="superapp-satc__status" data-sa-satc-status role="status" aria-live="polite" hidden></span></div>{%endif%}{%endcase%}
