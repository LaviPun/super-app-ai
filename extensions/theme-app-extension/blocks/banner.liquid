{% comment %}
  SuperApp Banner Block (Theme App Extension)

  This block is intended for the long-term pattern:
  - store config in shop metafields
  - render with an app block
  - avoid pushing theme assets directly

  For now, this is a simple configurable block.
{% endcomment %}

<section class="superapp-banner" role="region" aria-label="{{ block.settings.heading | escape }}">
  <div class="superapp-banner__inner">
    <div class="superapp-banner__content">
      <h2 class="superapp-banner__heading">{{ block.settings.heading | escape }}</h2>
      {% if block.settings.subheading != blank %}
        <p class="superapp-banner__subheading">{{ block.settings.subheading | escape }}</p>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SuperApp Banner",
  "target": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Hello" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "" }
  ]
}
{% endschema %}
