{% comment %}
  SuperApp Product Block
  Place inside a product template section to render a product-level module.
  Finds the module by ID in superapp.theme/module_refs (list.metaobject_reference) — API 2026-04+ compliant.
  activationType 'block' modules are designed for this slot. Markup comes from
  snippets/superapp-module.liquid; styles + runtime are wired once per page via
  this block's schema `stylesheet` / `javascript` attributes.
{% endcomment %}
{% assign module_id = block.settings.module_id | strip %}
{% if module_id != blank %}
  {% assign mod_refs = shop.metafields['superapp.theme']['module_refs'].value %}
  {% assign mod_ref = nil %}
  {% for ref in mod_refs %}
    {% if ref.fields.module_id.value == module_id %}
      {% assign mod_ref = ref %}
      {% break %}
    {% endif %}
  {% endfor %}

  {% if mod_ref %}
    <div class="superapp-slot superapp-slot--product" data-superapp-slot data-module-id="{{ module_id | escape }}">
      {% render 'superapp-module', mod_ref: mod_ref %}
    </div>
  {% endif %}
{% endif %}

{% schema %}
{
  "name": "SuperApp Product Block",
  "target": "section",
  "stylesheet": "superapp-modules.css",
  "javascript": "superapp-modules.js",
  "settings": [
    {
      "type": "text",
      "id": "module_id",
      "label": "Module ID",
      "info": "Paste a module ID from the app (e.g. from the module detail page). Intended for product-level modules such as frequently bought together, product upsells, or product description enhancers."
    }
  ]
}
{% endschema %}
