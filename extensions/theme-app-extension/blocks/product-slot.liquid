.","options": [{ "value": "inherit", "label": "Inherit" },{ "value": "none", "label": "None" },{ "value": "sm", "label": "Small" },{ "value": "md", "label": "Medium" },{ "value": "lg", "label": "Large" },{ "value": "xl", "label": "Extra large" }],"default": "inherit"},{"type": "select","id": "override_density","label": "Density","info": "Leave on Inherit to use the style pack / your theme.","options": [{ "value": "inherit", "label": "Inherit" },{ "value": "compact", "label": "Compact" },{ "value": "comfortable", "label": "Comfortable" },{ "value": "airy", "label": "Airy" }],"default": "inherit"},{"type": "select","id": "override_align","label": "Text alignment","info": "Leave on Inherit to use the style pack / your theme.","options": [{ "value": "inherit", "label": "Inherit" },{ "value": "left", "label": "Left" },{ "value": "center", "label": "Center" },{ "value": "right", "label": "Right" }],"default": "inherit"},{"type": "color","id": "override_text","label": "Text colour (optional)","info": "Leave empty to use the style pack / your theme."},{"type": "color","id": "override_bg","label": "Background colour (optional)","info": "Leave empty to use the style pack / your theme."}]}{%endschema%}
