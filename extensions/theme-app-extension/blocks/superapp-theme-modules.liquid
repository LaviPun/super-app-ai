{% assign mod_refs = shop.metafields['superapp.theme']['module_refs'].value %}
{% if mod_refs != blank %}
<div class="superapp-theme-modules" data-superapp-embed>
{% for mod_ref in mod_refs %}
{% assign act_type = mod_ref.fields.activation_type.value %}
{% unless act_type == 'section' or act_type == 'block' or act_type == 'head' %}
{% render 'superapp-module', mod_ref: mod_ref, style_pack: block.settings.style_pack, accent_override: block.settings.accent_override, override_radius: block.settings.override_radius, override_density: block.settings.override_density, override_align: block.settings.override_align, override_text: block.settings.override_text, override_bg: block.settings.override_bg %}
{% endunless %}
{% endfor %}
</div>
{% endif %}
{% schema %}
{
"name": "SuperApp Theme Modules",
"target": "body",
"stylesheet": "superapp-modules.css",
"javascript": "superapp-modules.js",
"settings": [
{
"type": "select",
"id": "style_pack",
"label": "Style pack (sitewide default)",
"info": "Design direction for popups, sitewide banners, effects and floating widgets. Auto picks the best match for your theme. Colours and fonts always inherit from your theme.",
"options": [
{ "value": "auto", "label": "Auto (match my theme)" },
{ "value": "luxe", "label": "Minimal Luxe" },
{ "value": "bold", "label": "Bold DTC" },
{ "value": "playful", "label": "Playful Commerce" },
{ "value": "utility", "label": "Tech Utility" }
],
"default": "auto"
},
{
"type": "color",
"id": "accent_override",
"label": "Accent colour (optional)",
"info": "Overrides the accent for global modules. Leave empty to inherit your brand accent."
},
{
"type": "select",
"id": "override_radius",
"label": "Corner radius (sitewide default)",
"info": "Sitewide default for global modules. Leave on Inherit to use the style pack / your theme.",
"options": [
{ "value": "inherit", "label": "Inherit" },
{ "value": "none", "label": "None" },
{ "value": "sm", "label": "Small" },
{ "value": "md", "label": "Medium" },
{ "value": "lg", "label": "Large" },
{ "value": "xl", "label": "Extra large" }
],
"default": "inherit"
},
{
"type": "select",
"id": "override_density",
"label": "Density (sitewide default)",
"info": "Sitewide default for global modules. Leave on Inherit to use the style pack / your theme.",
"options": [
{ "value": "inherit", "label": "Inherit" },
{ "value": "compact", "label": "Compact" },
{ "value": "comfortable", "label": "Comfortable" },
{ "value": "airy", "label": "Airy" }
],
"default": "inherit"
},
{
"type": "select",
"id": "override_align",
"label": "Text alignment (sitewide default)",
"info": "Sitewide default for global modules. Leave on Inherit to use the style pack / your theme.",
"options": [
{ "value": "inherit", "label": "Inherit" },
{ "value": "left", "label": "Left" },
{ "value": "center", "label": "Center" },
{ "value": "right", "label": "Right" }
],
"default": "inherit"
},
{
"type": "color",
"id": "override_text",
"label": "Text colour (optional, sitewide default)",
"info": "Sitewide default for global modules. Leave empty to use the style pack / your theme."
},
{
"type": "color",
"id": "override_bg",
"label": "Background colour (optional, sitewide default)",
"info": "Sitewide default for global modules. Leave empty to use the style pack / your theme."
}
]
}
{% endschema %}
