<div class="superapp-note">
  <div class="superapp-note__inner">
    <span class="superapp-note__msg">{{ block.settings.message | escape }}</span>
    {% if block.settings.link_text != blank and block.settings.link_url != blank %}
      <a class="superapp-note__link" href="{{ block.settings.link_url }}">{{ block.settings.link_text | escape }}</a>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "SuperApp Notification Bar",
  "target": "section",
  "settings": [
    { "type": "text", "id": "message", "label": "Message", "default": "Free shipping above ₹999" },
    { "type": "text", "id": "link_text", "label": "Link text", "default": "" },
    { "type": "url", "id": "link_url", "label": "Link URL" }
  ]
}
{% endschema %}
