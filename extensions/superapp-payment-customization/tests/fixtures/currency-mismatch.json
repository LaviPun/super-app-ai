{
  "payload": {
    "export": "cart_payment_methods_transform_run",
    "target": "cart.payment-methods.transform.run",
    "input": {
      "cart": {
        "cost": {
          "subtotalAmount": {
            "amount": "600.0",
            "currencyCode": "USD"
          }
        },
        "deliveryGroups": [],
        "lines": []
      },
      "paymentMethods": [
        {
          "id": "gid://shopify/PaymentCustomizationPaymentMethod/1",
          "name": "Cash on Delivery"
        }
      ],
      "shop": {
        "metaobject": {
          "field": {
            "jsonValue": {
              "rules": [
                {
                  "when": {
                    "currencyIn": [
                      "EUR"
                    ]
                  },
                  "actions": {
                    "hideMethodsContaining": [
                      "Cash on Delivery"
                    ]
                  }
                }
              ]
            }
          }
        }
      }
    },
    "output": {
      "operations": []
    }
  }
}