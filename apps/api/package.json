{
  "name": "@superapp/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "dev:cf": "wrangler dev",
    "deploy:cf": "wrangler deploy"
  },
  "dependencies": {
    "@superapp/db": "workspace:*",
    "@superapp/job-orchestration": "workspace:*",
    "@superapp/network-security": "workspace:*",
    "@superapp/observability": "workspace:*",
    "@superapp/platform-contracts": "workspace:*",
    "@superapp/workers": "workspace:*",
    "bullmq": "^5.76.10",
    "fastify": "^5.2.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250320.0",
    "@types/node": "^22.10.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.14.0"
  }
}
