# Railway / local — Fastify job API
NODE_ENV=production
HOST=0.0.0.0
PORT=3001
API_SERVICE_VERSION=0.1.0
JOB_EXECUTION_MODE=queue
QUEUE_PROVIDER=bullmq
JOB_STORE_PROVIDER=repository
QUEUE_REDIS_URL=redis://default:password@redis.railway.internal:6379
QUEUE_PREFIX=superapp-v2
QUEUE_DEFAULT_ATTEMPTS=3
QUEUE_DEFAULT_BACKOFF_MS=1000
DATABASE_URL=postgresql://user:pass@host:5432/superapp
