{
  "name": "web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "prisma db push --skip-generate && prisma generate && NODE_OPTIONS='--no-warnings' remix vite:dev",
    "dev:internal": "prisma db push --skip-generate && prisma generate && concurrently -k -n router,web -c blue,green \"pnpm run router:internal\" \"NODE_OPTIONS='--no-warnings' remix vite:dev --port 4000 --host 127.0.0.1\"",
    "build": "prisma generate && remix vite:build",
    "start": "remix-serve build/server/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint app scripts --format unix --max-warnings 100",
    "lint:fix": "eslint app scripts --fix",
    "prisma:migrate": "prisma migrate dev",
    "retention:run": "tsx --tsconfig tsconfig.scripts.json scripts/retention.ts",
    "seed:ai-pricing": "tsx --tsconfig tsconfig.scripts.json scripts/seed-ai-pricing.ts",
    "ai:routing-status": "tsx --tsconfig tsconfig.scripts.json scripts/ai-routing-status.ts",
    "router:internal": "tsx --tsconfig tsconfig.scripts.json scripts/internal-ai-router.ts",
    "evals": "tsx --tsconfig tsconfig.scripts.json scripts/run-evals.ts",
    "evals:strict": "pnpm evals --strict",
    "tournament": "tsx --tsconfig tsconfig.scripts.json scripts/run-tournament.ts",
    "tournament:fixture": "tsx --tsconfig tsconfig.scripts.json scripts/run-tournament-fixture.ts",
    "evals:live": "RUN_LIVE_EVALS=1 vitest run app/__tests__/evals.live.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "smoke:internal-ai": "tsx --tsconfig tsconfig.scripts.json scripts/smoke-internal-ai.ts"
  },
  "dependencies": {
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/sdk-trace-node": "^2.8.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@prisma/client": "^5.22.0",
    "@remix-run/node": "^2.17.5",
    "@remix-run/react": "^2.17.5",
    "@remix-run/serve": "^2.17.5",
    "@sentry/node": "^10.57.0",
    "@shopify/polaris": "^12.27.0",
    "@shopify/polaris-icons": "^9.3.1",
    "@shopify/shopify-api": "^11.14.1",
    "@shopify/shopify-app-remix": "^3.8.5",
    "@shopify/shopify-app-session-storage-prisma": "^5.2.3",
    "@superapp/core": "workspace:*",
    "@superapp/job-orchestration": "workspace:*",
    "@superapp/network-security": "workspace:*",
    "@superapp/platform-contracts": "workspace:*",
    "@superapp/rate-limit": "workspace:*",
    "@superapp/workers": "workspace:*",
    "@xyflow/react": "^12.11.0",
    "ioredis": "^5.11.1",
    "isbot": "^5.1.42",
    "linkedom": "^0.18.13",
    "openid-client": "^6.8.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@playwright/test": "^1.60.0",
    "@remix-run/dev": "^2.17.5",
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-formatter-unix": "^9.0.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prisma": "^5.22.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  }
}
