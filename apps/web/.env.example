DATABASE_URL="file:./dev.db"
SHOPIFY_API_KEY="replace-with-app-client-id"
SHOPIFY_API_SECRET="replace-with-app-client-secret"
SHOPIFY_APP_URL="http://localhost:3000"
ENCRYPTION_KEY="replace-with-32-byte-base64-key"

LLM_PROVIDER="openai"
OPENAI_API_KEY="replace-with-openai-api-key"
OPENAI_DEFAULT_MODEL="gpt-5-mini"

ANTHROPIC_API_KEY="replace-with-anthropic-api-key"
ANTHROPIC_DEFAULT_MODEL="claude-sonnet-4-6"
ANTHROPIC_SKILLS=""
ANTHROPIC_CODE_EXECUTION="false"

INTERNAL_ADMIN_PASSWORD="replace-with-strong-password"
INTERNAL_ADMIN_SESSION_SECRET="replace-with-random-secret"

INTERNAL_SSO_ISSUER="https://accounts.google.com"
INTERNAL_SSO_CLIENT_ID="replace-with-oidc-client-id"
INTERNAL_SSO_CLIENT_SECRET="replace-with-oidc-client-secret"
INTERNAL_SSO_REDIRECT_URI="https://your-app.example.com/internal/sso/callback"
INTERNAL_SSO_ALLOWED_EMAILS="ops@example.com,admin@example.com"

DEFAULT_RETENTION_DAYS="30"
CRON_SECRET="replace-with-long-random-secret"

INTERNAL_AI_ROUTER_URL="https://replace-with-router-url"
INTERNAL_AI_ROUTER_TOKEN="replace-with-router-token"
INTERNAL_AI_ROUTER_SHADOW="true"
