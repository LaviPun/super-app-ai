# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# -----------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------
# Local dev: SQLite. Production: use Postgres (postgresql://user:pass@host/db)
DATABASE_URL="file:./dev.db"

# -----------------------------------------------------------------------
# Shopify app credentials (from Partner Dashboard → App → API credentials)
# -----------------------------------------------------------------------
SHOPIFY_API_KEY="your-client-id-from-partner-dashboard"
SHOPIFY_API_SECRET="your-client-secret-from-partner-dashboard"

# Tunnel URL for local dev (use ngrok, cloudflare tunnel, or Shopify CLI tunnel)
# In production: your actual app URL
SHOPIFY_APP_URL="https://your-tunnel-or-prod-url.example.com"

# API scopes — keep in sync with shopify.app.toml [access_scopes]
SCOPES="write_themes,read_products,write_products,read_orders,write_discounts,write_checkouts,write_app_proxy,write_payment_customizations,write_delivery_customizations,write_cart_transforms"

# -----------------------------------------------------------------------
# Encryption key for connector secrets and API keys stored in DB
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# -----------------------------------------------------------------------
ENCRYPTION_KEY="<base64-encoded-32-byte-random-key>"

# -----------------------------------------------------------------------
# Internal developer dashboard (app-owner only, not visible to merchants)
# -----------------------------------------------------------------------
INTERNAL_ADMIN_PASSWORD="choose-a-strong-password-min-8-chars"
INTERNAL_ADMIN_SESSION_SECRET="choose-a-random-secret-min-16-chars"

# -----------------------------------------------------------------------
# Internal SSO (optional — OIDC/Google OAuth for the /internal/* dashboard)
# Leave blank to use password-only login.
# -----------------------------------------------------------------------
# INTERNAL_SSO_ISSUER="https://accounts.google.com"
# INTERNAL_SSO_CLIENT_ID="your-oauth-client-id"
# INTERNAL_SSO_CLIENT_SECRET="your-oauth-client-secret"
# INTERNAL_SSO_REDIRECT_URI="https://your-app.example.com/internal/sso/callback"

# -----------------------------------------------------------------------
# Data retention (days; applies to ApiLog, ErrorLog, AiUsage, Jobs)
# -----------------------------------------------------------------------
DEFAULT_RETENTION_DAYS="30"

# -----------------------------------------------------------------------
# Cron endpoint secret (optional)
# Protects GET /api/cron — called by external cron services to fire scheduled flows.
# Generate: openssl rand -hex 32
# -----------------------------------------------------------------------
# CRON_SECRET="<random-hex-32>"
