generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Prisma 5.x requires a literal datasource provider.
  // Keep SQLite as the default for local dev; Postgres cutover is documented in
  // docs/runbooks/postgres-migration.md as a controlled provider flip.
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Shop {
  id           String   @id @default(cuid())
  shopDomain   String   @unique
  accessToken  String
  planTier     String   @default("UNKNOWN")
  timezone     String?  // doc 24.4.1: plan_type (plus/non_plus) aligned via planTier
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  modules      Module[]
  connectors   Connector[]
  auditLogs    AuditLog[]
  aiUsages     AiUsage[]
  errorLogs    ErrorLog[]
  aiProviderOverrideId String?
  aiProviderOverride   AiProvider? @relation("ShopProviderOverride", fields: [aiProviderOverrideId], references: [id])
  retentionDaysDefault Int @default(30)
  retentionDaysAi Int?
  retentionDaysApi Int?
  retentionDaysErrors Int?
  apiLogs      ApiLog[]
  jobs         Job[]
  retentionPolicies RetentionPolicy[]
  themeProfiles ThemeProfile[]
  flowSchedules FlowSchedule[]
  flowStepLogs  FlowStepLog[]
  subscription  AppSubscription?
  activityLogs  ActivityLog[]
  dataStores    DataStore[]
  workflowDefs  WorkflowDef[]
  connectorTokens ConnectorToken[]
  recipes      Recipe[]
  moduleAssets ModuleAsset[]
  imageIngestionJobs ImageIngestionJob[]
  moduleInstances ModuleInstance[]
  dataCaptures DataCapture[]
  functionRuleSets FunctionRuleSet[]
  flowAssets   FlowAsset[]
  moduleEvents ModuleEvent[]
  moduleMetricsDaily ModuleMetricsDaily[]
  attributionLinks AttributionLink[]
}

model Recipe {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  category  String   // RECIPE_GOAL_CATEGORIES from manifest
  title     String
  version   Int      @default(1)
  createdAt DateTime @default(now())

  modules   Module[]

  @@index([shopId])
  @@index([shopId, category])
}

model Module {
  id         String   @id @default(cuid())
  shopId     String
  shop       Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  recipeId   String?
  recipe     Recipe?  @relation(fields: [recipeId], references: [id])
  type       String
  category   String
  name       String
  summary    String?  // doc 24.4.1 module_definitions
  status     String   @default("DRAFT")
  activeVersionId String? @unique
  // Design from Image (doc 24.4.1)
  sourceType String?  // template | recipe | scratch | image
  sourceJobId String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  versions   ModuleVersion[]
  activeVersion ModuleVersion? @relation("ActiveVersion", fields: [activeVersionId], references: [id])
  moduleAssets ModuleAsset[]
  imageIngestionJobs ImageIngestionJob[]
  moduleInstances ModuleInstance[]
  dataCaptures DataCapture[]
  functionRuleSets FunctionRuleSet[]
  flowAssets  FlowAsset[]
}

model ModuleVersion {
  id         String   @id @default(cuid())
  moduleId   String
  module     Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  version    Int
  status     String   @default("DRAFT")
  specJson   String   // RecipeSpec JSON
  compiledJson String? // optional compilation artifacts
  // doc 24.4.1 module_revisions
  diffSummary String?
  compiledArtifactsRef String?
  rollbackOfRevisionId String?

  publishedAt DateTime?
  targetThemeId String? // if theme-specific publish

  createdAt  DateTime @default(now())

  // Hydrate step: AI-generated full config envelope (schema, defaults, validation report)
  hydratedAt DateTime?
  adminConfigSchemaJson String?
  adminDefaultsJson String?
  themeEditorSettingsJson String?
  uiTokensJson String?
  validationReportJson String?
  implementationPlanJson String?  // AI hydrate output (implementation plan)
  previewHtmlJson String?         // AI-generated self-contained HTML preview
  compiledRuntimePlanJson String? // reserved for actual compiler output

  @@unique([moduleId, version])
  @@index([moduleId, status])

  activeFor   Module?  @relation("ActiveVersion")
  moduleInstances ModuleInstance[]
  moduleSettingsValues ModuleSettingsValues[]
}

model Connector {
  id         String   @id @default(cuid())
  shopId     String
  shop       Shop     @relation(fields: [shopId], references: [id])
  name       String
  baseUrl    String
  authType   String // API_KEY | BASIC | OAUTH2
  secretsEnc String // encrypted JSON blob
  allowlistDomains String // comma-separated allowlist
  lastTestedAt DateTime?
  sampleResponseJson String?
  mappingJson String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  endpoints  ConnectorEndpoint[]
}

model ConnectorEndpoint {
  id              String   @id @default(cuid())
  connectorId     String
  connector       Connector @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  name            String
  path            String
  method          String   @default("GET") // GET | POST | PUT | PATCH | DELETE
  defaultHeaders  String?  // JSON key-value
  defaultBody     String?  // JSON or raw text
  sortOrder       Int      @default(0)
  lastTestedAt    DateTime?
  lastStatus      Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([connectorId, sortOrder])
}

model AuditLog {
  id         String   @id @default(cuid())
  shopId     String
  shop       Shop     @relation(fields: [shopId], references: [id])
  action     String
  details    String?
  createdAt  DateTime @default(now())
}


model Session {
  id            String   @id
  shop          String
  state         String
  isOnline      Boolean  @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean  @default(false)
  locale        String?
  collaborator  Boolean? @default(false)
  emailVerified Boolean? @default(false)
}

model AiProvider {
  id          String   @id @default(cuid())
  name        String
  provider    String   // OPENAI | ANTHROPIC | AZURE_OPENAI | CUSTOM
  baseUrl     String?
  model       String?
  apiKeyEnc   String   // encrypted
  isActive    Boolean  @default(false)
  costInPer1kCents  Int? // optional accounting
  costOutPer1kCents Int?
  /// JSON: ANTHROPIC-only { skills?: string[], codeExecution?: boolean }; skills = anthropic IDs e.g. pptx, xlsx or custom skill_01Ab...
  extraConfig String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  usages      AiUsage[]
  prices      AiModelPrice[]
  shopOverrides Shop[] @relation("ShopProviderOverride")
}

model AiUsage {
  id          String   @id @default(cuid())
  providerId  String
  provider    AiProvider @relation(fields: [providerId], references: [id])
  shopId      String?
  shop        Shop?     @relation(fields: [shopId], references: [id])
  action      String    // e.g. RECIPE_GENERATION, MAPPING_SUGGESTION
  tokensIn    Int
  tokensOut   Int
  costCents   Int
  meta        String?   // JSON
  /// Optional cross-request correlation id (set by ApiLog/Job/AiUsage) so a single
  /// merchant-facing operation can be reconstructed from any starting point.
  correlationId String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([shopId, createdAt])
  @@index([correlationId])
  requestCount Int @default(1)
}

model ErrorLog {
  id        String   @id @default(cuid())
  level     String   // INFO | WARN | ERROR
  message   String
  stack     String?
  route     String?
  source    String?  // API | ERROR_BOUNDARY | CLIENT | SERVER
  shopId    String?
  shop      Shop?    @relation(fields: [shopId], references: [id])
  meta      String?
  /// Server-side request id (matches ApiLog.requestId for the originating request).
  requestId     String?
  /// Cross-request correlation id; mirrors ApiLog/Job/AiUsage for full trace assembly.
  correlationId String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([level, createdAt])
  @@index([source, createdAt])
  @@index([requestId])
  @@index([correlationId])
}

model AiModelPrice {
  id        String   @id @default(cuid())
  providerId String
  provider  AiProvider @relation(fields: [providerId], references: [id])
  model     String
  inputPer1MTokensCents       Int
  outputPer1MTokensCents      Int
  cachedInputPer1MTokensCents Int?
  isActive  Boolean  @default(true)
  effectiveFrom DateTime @default(now())
  createdAt DateTime @default(now())

  @@unique([providerId, model, effectiveFrom])
  @@index([providerId, isActive])
}

model ApiLog {
  id         String    @id @default(cuid())
  shopId     String?
  shop       Shop?     @relation(fields: [shopId], references: [id])
  actor      String    // INTERNAL | MERCHANT | WEBHOOK | APP_PROXY
  method     String
  path       String
  status     Int      // 0 = in progress, else HTTP status
  durationMs Int
  requestId  String?
  /// Cross-request correlation id; same id is propagated to Job/ErrorLog/AiUsage/FlowStepLog
  /// for any work spawned by this request, so the operator can reconstruct an entire trace
  /// from any single record.
  correlationId String?
  success    Boolean
  meta       String?
  createdAt  DateTime  @default(now())
  finishedAt DateTime? // null = request still running

  @@index([createdAt])
  @@index([shopId, createdAt])
  @@index([path, createdAt])
  @@index([finishedAt])
  @@index([correlationId])
  @@index([requestId])
}

model Job {
  id        String   @id @default(cuid())
  shopId    String?
  shop      Shop?    @relation(fields: [shopId], references: [id])
  type      String   // AI_GENERATE | PUBLISH | CONNECTOR_TEST | FLOW_RUN | THEME_ANALYZE
  status    String   // QUEUED | RUNNING | SUCCESS | FAILED
  attempts  Int      @default(0)
  payload   String?
  result    String?
  error     String?
  /// Inherits the originating request's requestId (if any) so we can chain a job back
  /// to the API call that scheduled it.
  requestId     String?
  /// Inherits the originating request's correlationId; child FlowStepLogs and AiUsage
  /// records share this id for end-to-end trace assembly.
  correlationId String?
  startedAt DateTime?
  finishedAt DateTime?
  createdAt DateTime @default(now())

  @@index([status, createdAt])
  @@index([shopId, createdAt])
  @@index([requestId])
  @@index([correlationId])
}

model WebhookEvent {
  id            String   @id @default(cuid())
  shopDomain    String
  topic         String
  eventId       String   // Shopify webhook X-Shopify-Webhook-Id header
  processedAt   DateTime @default(now())
  success       Boolean  @default(true)

  @@unique([shopDomain, topic, eventId])
  @@index([shopDomain, topic])
  @@index([processedAt])
}

model FlowStepLog {
  id         String   @id @default(cuid())
  jobId      String
  shopId     String?
  shop       Shop?    @relation(fields: [shopId], references: [id])
  step       Int
  kind       String
  status     String   // SUCCESS | FAILED | SKIPPED
  durationMs Int
  output     String?
  error      String?
  /// Cross-request correlation id; mirrors the parent Job.correlationId so step logs
  /// can be joined to the originating ApiLog/AiUsage chain without a Job join.
  correlationId String?
  createdAt  DateTime @default(now())

  @@index([jobId])
  @@index([shopId])
  @@index([correlationId])
}

model PlanTierConfig {
  id          String   @id @default(cuid())
  name        String   @unique // FREE | STARTER | GROWTH | PRO
  displayName String
  price       Int      // USD/month
  trialDays   Int
  quotasJson  String   // JSON: { aiRequestsPerMonth, publishOpsPerMonth, ... }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AppSubscription {
  id              String   @id @default(cuid())
  shopId          String   @unique
  shop            Shop     @relation(fields: [shopId], references: [id])
  planName        String
  shopifySubId    String?
  status          String   @default("ACTIVE") // ACTIVE | CANCELLED | EXPIRED
  trialEndsAt     DateTime?
  currentPeriodEnd DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model RetentionPolicy {
  id        String   @id @default(cuid())
  scope     String   // GLOBAL | PLAN | SHOP
  planTier  String?
  shopId    String?
  shop      Shop?    @relation(fields: [shopId], references: [id])
  kind      String   // AI_USAGE | API_LOG | ERROR_LOG | JOBS
  days      Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([scope, kind, isActive])
  @@index([shopId, kind, isActive])
}

model ThemeProfile {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id])
  themeId   String
  profileJson String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shopId, themeId])
}

model AppSettings {
  id        String  @id @default("singleton")
  // Appearance
  appName         String  @default("SuperApp AI")
  headerColor     String  @default("#000000")
  logoUrl         String? // URL or data-uri for the logo image
  faviconUrl      String?
  // Profile
  adminName       String  @default("Admin")
  adminEmail      String?
  profilePicUrl   String? // URL or data-uri for avatar
  // Contact
  companyName     String?
  supportEmail    String?
  supportUrl      String?
  privacyUrl      String?
  termsUrl        String?
  // App config
  defaultTimezone String  @default("UTC")
  dateFormat      String  @default("YYYY-MM-DD")
  enableEmailAlerts Boolean @default(false)
  alertRecipients   String? // comma-separated emails
  maintenanceMode   Boolean @default(false)
  maintenanceMessage String?
  // Admin: type category overrides (JSON: { [category]: { displayName?, enabled? } })
  categoryOverrides  String?
  // Admin: template spec overrides (JSON: { [templateId]: RecipeSpec } for recipe-edit "All recipes")
  templateSpecOverrides String?
  // Default AI provider when using .env keys: openai | claude (null = use DB active, then OpenAI env fallback)
  defaultAiProvider String?
  // Optional URL used as premium UI/UX visual reference when compiling storefront AI prompts.
  designReferenceUrl String?
  // Encrypted JSON runtime settings for first-layer router target switching (localMachine/modalRemote)
  routerRuntimeConfigEnc String?
  // Meta
  updatedAt DateTime @updatedAt
}

model ActivityLog {
  id            String   @id @default(cuid())
  actor         String   // SYSTEM | MERCHANT | INTERNAL_ADMIN | WEBHOOK | CRON
  action        String   // e.g. MODULE_CREATED, MODULE_PUBLISHED, CONNECTOR_CREATED, SCHEDULE_CREATED, LOGIN, etc.
  resource      String?  // e.g. "module:clxxx", "connector:clxxx"
  shopId        String?
  shop          Shop?    @relation(fields: [shopId], references: [id])
  details       String?  // JSON metadata
  ip            String?
  requestId     String?
  correlationId String?
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@index([actor, createdAt])
  @@index([action, createdAt])
  @@index([shopId, createdAt])
  @@index([requestId])
  @@index([correlationId])
}

model FlowSchedule {
  id          String    @id @default(cuid())
  shopId      String
  shop        Shop      @relation(fields: [shopId], references: [id])
  name        String
  // Cron expression (e.g. "0 9 * * 1" = every Monday 09:00 UTC)
  cronExpr    String
  // ISO event payload forwarded to FlowRunnerService
  eventJson   String    @default("{}")
  isActive    Boolean   @default(true)
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([shopId, isActive])
  @@index([nextRunAt, isActive])
}

model DataStore {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id])
  key         String   // product | inventory | order | analytics | marketing | custom
  label       String
  description String?
  icon        String?  // icon name hint
  isEnabled   Boolean  @default(true)
  schemaJson  String?  // optional column/field schema for the store
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  records     DataStoreRecord[]

  @@unique([shopId, key])
  @@index([shopId, isEnabled])
}

model DataStoreRecord {
  id          String   @id @default(cuid())
  dataStoreId String
  dataStore   DataStore @relation(fields: [dataStoreId], references: [id], onDelete: Cascade)
  customerId  String?
  externalId  String?  // e.g. Shopify product GID, order ID, etc.
  title       String?  // human-readable label for the record
  payload     String   // JSON document
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([dataStoreId, createdAt])
  @@index([dataStoreId, externalId])
  @@index([customerId])
}

// ─── Workflow Engine (graph-based automation) ──────────────────────────

model WorkflowDef {
  id          String   @id @default(cuid())
  tenantId    String   // shopId
  shop        Shop     @relation(fields: [tenantId], references: [id])
  workflowId  String   // logical workflow ID from the JSON spec
  version     Int
  name        String
  status      String   @default("draft") // draft | active | paused | archived
  specJson    String   // full Workflow JSON (nodes/edges/trigger/settings)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  runs        WorkflowRun[]

  @@unique([tenantId, workflowId, version])
  @@index([tenantId, status])
}

model WorkflowRun {
  id              String   @id @default(cuid())
  workflowId      String   // logical workflow ID
  workflowVersion Int
  tenantId        String   // shopId
  status          String   @default("QUEUED") // QUEUED | RUNNING | SUCCEEDED | FAILED | CANCELLED | TIMED_OUT
  triggerRef      String?  // JSON: { provider, event }
  contextJson     String?  // full RunContext JSON (for crash recovery)
  error           String?
  startedAt       DateTime?
  endedAt         DateTime?
  createdAt       DateTime @default(now())

  workflowDef     WorkflowDef? @relation(fields: [workflowId, workflowVersion, tenantId], references: [workflowId, version, tenantId])
  steps           WorkflowRunStep[]

  @@index([workflowId, tenantId])
  @@index([tenantId, status])
  @@index([createdAt])
}

model WorkflowRunStep {
  id          String   @id @default(cuid())
  runId       String
  run         WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  stepId      String   // node ID from the workflow spec
  nodeType    String   // condition | action | transform | delay | end
  nodeName    String
  status      String   // PENDING | RUNNING | SUCCESS | FAILED | RETRYING | SKIPPED | WAITING
  attempt     Int      @default(0)
  startedAt   DateTime?
  endedAt     DateTime?
  durationMs  Int?
  inputsJson  String?  // redacted inputs
  resultJson  String?  // redacted result
  error       String?
  createdAt   DateTime @default(now())

  @@index([runId])
  @@index([runId, stepId])
}

model ConnectorToken {
  id          String   @id @default(cuid())
  tenantId    String   // shopId
  shop        Shop     @relation(fields: [tenantId], references: [id])
  provider    String   // shopify | slack | email | custom
  authType    String   // oauth | api_key | shopify | none
  secretsEnc  String   // encrypted JSON blob (access token, refresh token, etc.)
  scopes      String?  // comma-separated scopes
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, provider])
  @@index([tenantId])
}

// ─── Doc 24.4.1 Operational DB + 24.4.2 Analytics ─────────────────────────────

model ModuleAsset {
  id           String   @id @default(cuid())
  shopId       String
  shop         Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  moduleId     String
  module       Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  revisionId   String?
  assetType    String   // image_reference | generated_mock | exported_preview
  storageRef   String   // S3/blob key
  width        Int?
  height       Int?
  mime         String?
  createdAt    DateTime @default(now())

  @@index([shopId])
  @@index([moduleId])
}

model ImageIngestionJob {
  id                      String   @id @default(cuid())
  shopId                  String
  shop                    Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  moduleId                String
  module                  Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  status                  String   // queued | processing | complete | failed
  inputAssetIds           String   // JSON array
  detectedSurfaceHint     String?  // theme | checkout | admin | pos
  extractionResult        String?  // JSON
  generatedUiTree         String?  // JSON
  generatedSettingsSchema String?  // JSON
  createdAt               DateTime @default(now())
  completedAt             DateTime?

  @@index([shopId])
  @@index([moduleId])
  @@index([status])
}

model ModuleInstance {
  id                  String   @id @default(cuid())
  shopId              String
  shop                Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  moduleId            String
  module              Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  revisionId          String
  revision            ModuleVersion @relation(fields: [revisionId], references: [id])
  surfaceType         String
  target              String
  filters             String?  // JSON
  enabled             Boolean  @default(true)
  themeId             String?
  themeSectionId      String?
  checkoutProfileId    String?
  posLocationId       String?
  createdAt           DateTime @default(now())

  moduleSettingsValues ModuleSettingsValues[]
  dataCaptures         DataCapture[]
  moduleEvents         ModuleEvent[]
  moduleMetricsDaily   ModuleMetricsDaily[]

  @@index([shopId])
  @@index([moduleId])
  @@index([revisionId])
}

model ModuleSettingsValues {
  instanceId      String
  instance        ModuleInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  revisionId      String
  revision        ModuleVersion @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  settingsValues  String   // JSON
  updatedAt       DateTime @updatedAt

  @@id([instanceId, revisionId])
}

model DataCapture {
  id                   String   @id @default(cuid())
  shopId               String
  shop                 Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  instanceId           String
  instance             ModuleInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  moduleId             String
  module               Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  customerId           String?
  captureType          String   // survey_response | return_request | support_ticket | note | preference
  payloadSchemaVersion String
  payload              String   // JSON
  piiFlags             String?  // JSON
  createdAt            DateTime @default(now())

  @@index([shopId])
  @@index([instanceId])
  @@index([moduleId])
  @@index([customerId])
  @@index([createdAt])
}

model FunctionRuleSet {
  id         String   @id @default(cuid())
  shopId     String
  shop       Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  functionApi String
  moduleId   String
  module     Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  config     String   // JSON
  status     String   @default("active") // active | inactive
  createdAt  DateTime @default(now())

  @@index([shopId])
  @@index([moduleId])
}

model FlowAsset {
  id         String   @id @default(cuid())
  shopId     String
  shop       Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  moduleId   String
  module     Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  kind       String   // trigger | action | template
  status     String
  createdAt  DateTime @default(now())

  @@index([shopId])
  @@index([moduleId])
}

model ModuleEvent {
  id                String   @id @default(cuid())
  timestamp         DateTime @default(now())
  shopId            String
  shop              Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  moduleId          String
  instanceId        String?
  instance          ModuleInstance? @relation(fields: [instanceId], references: [id], onDelete: SetNull)
  customerId        String?
  revisionId        String?
  recipeId          String?
  category          String?
  surfaceType       String?
  target            String?
  templateContext   String?
  sessionId         String?
  visitorId         String?
  userType          String?  // buyer | merchant | staff
  eventName         String
  eventProperties   String?  // JSON
  valueMetrics      String?  // JSON
  piiFlags          String?  // JSON
  correlationIds    String?  // JSON

  @@index([shopId])
  @@index([moduleId])
  @@index([instanceId])
  @@index([customerId])
  @@index([timestamp])
  @@index([eventName])
}

model ModuleMetricsDaily {
  id             String   @id @default(cuid())
  date           DateTime // date-only for daily aggregate (SQLite: store as datetime)
  shopId         String
  shop           Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  moduleId      String
  instanceId    String?
  instance       ModuleInstance? @relation(fields: [instanceId], references: [id], onDelete: SetNull)
  surfaceType   String?
  target         String?
  impressions   Int      @default(0)
  interactions  Int      @default(0)
  actions       Int      @default(0)
  conversions   Int      @default(0)
  errors        Int      @default(0)
  dataCaptures  Int      @default(0)
  updatedAt     DateTime @updatedAt

  @@unique([date, shopId, moduleId, instanceId])
  @@index([shopId])
  @@index([moduleId])
  @@index([date])
}

model AttributionLink {
  id             String   @id @default(cuid())
  shopId         String
  shop           Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  sessionId      String
  visitorId      String?
  customerId     String?
  checkoutToken  String?
  orderId        String?
  firstSeenAt    DateTime @default(now())
  lastSeenAt     DateTime @updatedAt
  source         String?  // pixel | theme | checkout-ui

  @@index([shopId])
  @@index([sessionId])
  @@index([customerId])
  @@index([orderId])
}

model InternalAiSession {
  id            String   @id @default(cuid())
  title         String
  mode          String   @default("localMachine") // localMachine | modalRemote
  memoryEnabled Boolean  @default(true)
  archivedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  messages      InternalAiMessage[]
  toolAudits    InternalAiToolAudit[]

  @@index([updatedAt])
  @@index([createdAt])
}

model InternalAiMessage {
  id             String   @id @default(cuid())
  sessionId      String
  session        InternalAiSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role           String   // user | assistant | system
  content        String
  mode           String?  // localMachine | modalRemote
  backend        String?  // ollama | openai | qwen3 | custom
  model          String?
  latencyMs      Int?
  tokensIn       Int?
  tokensOut      Int?
  estimatedCostCents Int? @default(0)
  hadFallback    Boolean  @default(false)
  retryCount     Int      @default(0)
  status         String   @default("completed") // streaming | completed | error
  clientRequestId String?
  responseToMessageId String?
  error          String?
  createdAt      DateTime @default(now())

  toolAudits     InternalAiToolAudit[]

  @@index([sessionId, createdAt])
  @@index([sessionId, clientRequestId])
  @@index([responseToMessageId])
  @@index([createdAt])
}

model InternalAiMemory {
  id          String   @id @default(cuid())
  title       String
  content     String
  tagsJson    String? // JSON string[]
  isEnabled   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isEnabled, updatedAt])
}

model InternalAiToolAudit {
  id          String   @id @default(cuid())
  sessionId   String?
  session     InternalAiSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  messageId   String?
  message     InternalAiMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)
  toolName    String
  argsJson    String?
  resultJson  String?
  success     Boolean  @default(true)
  error       String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([toolName, createdAt])
  @@index([sessionId, createdAt])
}
